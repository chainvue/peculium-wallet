# ─────────────────────────────────────────────────────────────────────────
# NO PRIVATE KEY EVER GOES IN ENV. Not as WIF, not as seed, not "just for
# testing". The spending key lives ONLY in the encrypted keystore that
# `peculium init` creates (~/.peculium/<chain>/keystore.json).
# ─────────────────────────────────────────────────────────────────────────

# Passphrase that unlocks the keystore at MCP-server start. Set this in the
# MCP host config (env block) — it protects the keystore AT REST (backups,
# other users), not against same-user malware. See DESIGN.md §3.
PECULIUM_KEYSTORE_PASSPHRASE=

# Public Verus node the wallet talks to (read UTXOs/balances/identities,
# broadcast signed txs). Defaults to the official public testnet node.
# PECULIUM_NODE_URL=https://api.verustest.net

# Override the config directory (default: ~/.peculium)
# PECULIUM_DIR=

# ── Gated live tests only (never needed to run the wallet) ──────────────
# Robert's LAN VRSCTEST node for the integration harness; unset → suites skip.
# VERUS_RPC_URL=http://127.0.0.1:18843
# VERUS_RPC_USER=
# VERUS_RPC_PASS=
# Value-moving write harness (dust sends on VRSCTEST) — explicit opt-in.
# PECULIUM_ALLOW_SPEND=1
