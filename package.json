{
  "name": "@chainvue/peculium-wallet",
  "version": "0.2.2",
  "description": "Peculium — the safe Verus wallet for AI agents. MCP server + CLI: local offline signing, public nodes, human-configured policy the agent cannot change.",
  "license": "Apache-2.0",
  "author": "Robert Lech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chainvue/peculium-wallet.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "peculium": "dist/main.js"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "sideEffects": false,
  "keywords": [
    "verus",
    "vrsc",
    "wallet",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "agent-payments",
    "verusid",
    "v402"
  ],
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "@chainvue/v402-client-fetch": "^0.2.0",
    "@chainvue/v402-protocol": "^0.2.0",
    "@chainvue/v402-signer-verus": "^0.1.2",
    "@chainvue/verus-rpc": "^0.2.0",
    "@chainvue/verus-sdk": "^0.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "semantic-release": "^25.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
